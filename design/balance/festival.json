        { "id": "write_couplet", "name": "写春联", "type": "minigame", "target": "couplet_writing", "amount": 1, "contribution": 20 },
        { "id": "firecracker", "name": "放鞭炮", "type": "minigame", "target": "firecracker_game", "amount": 1, "contribution": 20 },
        { "id": "visit_neighbors", "name": "拜年", "type": "interact", "target": "villagers", "amount": 5, "contribution": 25 }
      ],
      "rewards": {
        "BASIC": [{ "type": "coins", "amount": 300 }],
        "GOOD": [{ "type": "coins", "amount": 600 }, { "type": "item", "id": "stamina_potion_large", "amount": 2 }],
        "PERFECT": [{ "type": "coins", "amount": 1200 }, { "type": "item", "id": "stamina_potion_full", "amount": 2 }, { "type": "unlock", "id": "spring_festival_outfit" }]
      }
    }
  ],

  "notes": {
    "prepDays": "准备期天数",
    "afterglowDays": "余韵期天数",
    "contribution": "任务对完成度的贡献百分比",
    "gameDay": "年内第几天（1-28）"
  }
