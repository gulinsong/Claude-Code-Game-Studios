{
  "$schema": "./schemas/festival.schema.json",
  "version": "1.0.0",
  "description": "节日系统配置 - 节日定义、任务、奖励",

  "prepDays": 3,
  "afterglowDays": 1,

  "rewardTiers": {
    "BASIC": { "minCompletion": 0, "maxCompletion": 49 },
    "GOOD": { "minCompletion": 50, "maxCompletion": 99 },
    "PERFECT": { "minCompletion": 100, "maxCompletion": 100 }
  },

  "festivals": [
    {
      "id": "qingming",
