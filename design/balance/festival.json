      "tasks": [
        { "id": "make_mooncake", "name": "做月饼", "type": "craft", "target": "mooncake", "amount": 6, "contribution": 25 },
        { "id": "make_lantern", "name": "做灯笼", "type": "craft", "target": "lantern", "amount": 2, "contribution": 25 },
