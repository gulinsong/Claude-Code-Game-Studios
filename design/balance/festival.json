      "lore": "端午节是中国四大传统节日之一...",
      "tasks": [
        { "id": "make_zongzi", "name": "包粽子", "type": "craft", "target": "zongzi", "amount": 8, "contribution": 30 },
        { "id": "gather_reeds", "name": "采集苇叶", "type": "gather", "target": "reed", "amount": 15, "contribution": 20 },
        { "id": "dragon_boat", "name": "赛龙舟", "type": "minigame", "target": "dragon_boat_race", "amount": 1, "contribution": 30 },
        { "id": "hang_mugwort", "name": "挂艾草", "type": "interact", "target": "home_door", "amount": 1, "contribution": 20 }
