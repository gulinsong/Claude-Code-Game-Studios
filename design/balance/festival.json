        "PERFECT": [{ "type": "coins", "amount": 800 }, { "type": "item", "id": "stamina_potion_full", "amount": 1 }, { "type": "recipe", "id": "premium_mooncake" }]
      }
    },
    {
      "id": "chunjie",
      "name": "春节",
      "season": "WINTER",
      "gameDay": 28,
      "description": "春节，中国最重要的传统节日。",
