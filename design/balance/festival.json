      "description": "清明节，踏青祭祖的传统节日。",
      "lore": "清明节是中国最重要的祭祀节日之一...",
      "tasks": [
        { "id": "make_qingtuan", "name": "制作青团", "type": "craft", "target": "qingtuan", "amount": 5, "contribution": 25 },
        { "id": "gather_herbs", "name": "采集艾草", "type": "gather", "target": "herb", "amount": 10, "contribution": 20 },
        { "id": "visit_ancestor", "name": "祭拜先祖", "type": "interact", "target": "ancestor_shrine", "amount": 1, "contribution": 30 },
        { "id": "fly_kite", "name": "放风筝", "type": "minigame", "target": "kite_flying", "amount": 1, "contribution": 25 }
      ],
      "rewards": {
        "BASIC": [{ "type": "coins", "amount": 100 }],
        "GOOD": [{ "type": "coins", "amount": 200 }, { "type": "item", "id": "stamina_potion_small", "amount": 2 }],
        "PERFECT": [{ "type": "coins", "amount": 400 }, { "type": "item", "id": "stamina_potion_large", "amount": 1 }, { "type": "recipe", "id": "premium_qingtuan" }]
      }
    },
    {
      "id": "duanwu",
      "name": "端午",
